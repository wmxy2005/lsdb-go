LSDB_ADDR=:8080
LSDB_DB_PATH=data/test.db
LSDB_FILE_ROOT=data/files
LSDB_FRONTEND_DIST=
LSDB_GIN_MODE=
LSDB_JWT_SECRET=dev-secret-change-me
LSDB_JWT_EXPIRE_DAYS=7
LSDB_JWT_REFRESH_DAYS=2
LSDB_CMD_SKIP_AUTH=false
LSDB_MONITOR_IDLE_TIMEOUT=30s
# Leave empty to disable CORS; set dev server origins for cross-origin API access during development
LSDB_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTO_RUN_SERVER=true
AUTO_RUN_MINIMIZE=true
